---
import Layout from '../layouts/Layout.astro';

const agendaItems = [
  {
    datum: 'Zondag 31 mei 2026',
    tijd: '10u',
    titel: 'Officiële opening'
  },
  {
    datum: 'Zondag 31 mei 2026',
    tijd: '11u tot 18u',
    titel: 'Kunstcafé'
  },
  {
    datum: 'Zondag 31 mei 2026',
    tijd: '13u30',
    titel: 'Sip & Paint (met inschrijving)',
    href: '/sip-and-paint/'
  },
  {
    datum: 'Zondag 31 mei 2026',
    tijd: '16u',
    titel: 'Sip & Paint (met inschrijving)',
    href: '/sip-and-paint/'
  },
  {
    datum: 'Zondag 7 juni 2026',
    tijd: '11u tot 18u',
    titel: 'Kunstcafé'
  },
  {
    datum: 'Zondag 14 juni 2026',
    tijd: '11u',
    titel: 'Gratis tuinconcert met Otsamo - kleurrijke Indiepop'
  },
  {
    datum: 'Zondag 14 juni 2026',
    tijd: '11u tot 18u',
    titel: 'Kunstcafé'
  },
  {
    datum: 'Zondag 21 juni 2026',
    tijd: '11u tot 18u',
    titel: 'Kunstcafé'
  }
];
---

<Layout
  title="Agenda | Kunst On(t)leed"
  description="Bekijk de agenda van Kunst On(t)leed in Gits en ontdek wanneer de activiteiten en bezoekmomenten plaatsvinden."
>
  <section class="agenda-hero">
    <p class="agenda-kicker">Plan je bezoek</p>
    <h1>Agenda</h1>
  </section>

  <section class="agenda-list">
    {agendaItems.map((item) => (
      <article class="agenda-card">
        <div class="agenda-meta">
          <p class="agenda-date">{item.datum}</p>
          <p class="agenda-time">{item.tijd}</p>
        </div>

        <div class="agenda-content">
          {item.href ? (
            <h2>
              <a href={item.href} class="agenda-title-link">{item.titel}</a>
            </h2>
          ) : (
            <h2>{item.titel}</h2>
          )}
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>
  .agenda-hero {
    padding: 2rem 0 0.5rem;
    max-width: 760px;
  }

  .agenda-kicker {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .agenda-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.95;
  }

  .agenda-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2rem;
    padding-bottom: 2.75rem;
  }

  .agenda-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    background: linear-gradient(180deg, rgba(251, 243, 230, 0.96), rgba(245, 234, 215, 0.92));
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
  }

  .agenda-meta p {
    margin: 0;
  }

  .agenda-date {
    font-weight: 700;
    color: var(--title);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.9rem;
  }

  .agenda-time {
    margin-top: 0.6rem !important;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .agenda-content {
    display: flex;
    align-items: center;
  }

  .agenda-content h2 {
    margin: 0;
    font-size: 2rem;
    line-height: 1.05;
  }

  .agenda-title-link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .agenda-title-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 800px) {
    .agenda-hero {
      padding: 1rem 0 0.35rem;
    }

    .agenda-kicker {
      margin-bottom: 0.55rem;
      font-size: 0.8rem;
    }

    .agenda-hero h1 {
      font-size: clamp(2.6rem, 12vw, 3.6rem);
    }

    .agenda-list {
      gap: 1rem;
      margin-top: 1.5rem;
      padding-bottom: 2.2rem;
    }

    .agenda-card {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.2rem;
    }

    .agenda-content {
      display: block;
    }

    .agenda-content h2 {
      font-size: 1.7rem;
    }
  }
</style>