---
import Layout from '../layouts/Layout.astro';

const agendaItems = [
  {
    datum: 'Vrijdag 12 september 2026',
    tijd: '19:00 – 22:00',
    titel: 'Openingsavond',
    beschrijving:
      'Feestelijke start van Kunst on(t)leed met de eerste bezoekers op het parcours.'
  },
  {
    datum: 'Zaterdag 13 september 2026',
    tijd: '14:00 – 18:00',
    titel: 'Kunstenaars in gesprek',
    beschrijving:
      'Bezoekers kunnen op verschillende locaties kunstenaars ontmoeten en meer horen over hun werk.'
  },
  {
    datum: 'Zaterdag 13 september 2026',
    tijd: '19:00 – 21:00',
    titel: 'Avondmoment op het parcours',
    beschrijving:
      'Een extra sfeervol moment op het parcours met bijzondere accenten in de beleving.'
  },
  {
    datum: 'Zondag 14 september 2026',
    tijd: '10:00 – 17:00',
    titel: 'Doorlopende openstelling',
    beschrijving:
      'Het parcours is vrij te bezoeken en alle deelnemende locaties zijn open voor het publiek.'
  }
];
---

<Layout
  title="Agenda | Kunst on(t)leed"
  description="Bekijk de agenda van Kunst on(t)leed in Gits en ontdek wanneer de activiteiten en bezoekmomenten plaatsvinden."
>
  <section class="agenda-hero">
    <p class="agenda-kicker">Plan je bezoek</p>
    <h1>Agenda</h1>
    <p class="agenda-intro">
      Hier vind je een overzicht van de geplande momenten tijdens Kunst on(t)leed.
      Deze data en uren zijn voorlopig voorbeeldinhoud en kunnen later eenvoudig aangepast worden.
    </p>
  </section>

  <section class="agenda-list">
    {agendaItems.map((item) => (
      <article class="agenda-card">
        <div class="agenda-meta">
          <p class="agenda-date">{item.datum}</p>
          <p class="agenda-time">{item.tijd}</p>
        </div>

        <div class="agenda-content">
          <h2>{item.titel}</h2>
          <p>{item.beschrijving}</p>
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>
  .agenda-hero {
    padding: 2rem 0 1rem;
    max-width: 760px;
  }

  .agenda-kicker {
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .agenda-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.95;
  }

  .agenda-intro {
    margin-top: 1.25rem;
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 700px;
  }

  .agenda-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .agenda-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    background-color: rgba(251, 243, 230, 0.8);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
  }

  .agenda-meta p {
    margin: 0;
  }

  .agenda-date {
    font-weight: 700;
    color: var(--title);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.9rem;
  }

  .agenda-time {
    margin-top: 0.6rem !important;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .agenda-content h2 {
    margin: 0 0 0.75rem 0;
    font-size: 2rem;
    line-height: 1;
  }

  .agenda-content p {
    margin: 0;
    line-height: 1.75;
  }

  @media (max-width: 800px) {
    .agenda-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .agenda-content h2 {
      font-size: 1.7rem;
    }
  }
</style>