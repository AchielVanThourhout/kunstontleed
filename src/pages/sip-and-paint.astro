---
import Layout from '../layouts/Layout.astro';

const sfeerbeelden = [
  {
    src: '/images/sip-and-paint/workshop-1.jpg',
    alt: 'Sfeerbeeld van de Sip & Paint-workshop',
  },
  {
    src: '/images/sip-and-paint/resultaat-1.jpg',
    alt: 'Resultaat van een Sip & Paint-workshop',
  },
  {
    src: '/images/sip-and-paint/workshop-2.jpg',
    alt: 'Deelnemers tijdens de Sip & Paint-workshop',
  },
  {
    src: '/images/sip-and-paint/resultaat-2.jpg',
    alt: 'Schilderij gemaakt tijdens Sip & Paint',
  },
  {
    src: '/images/sip-and-paint/workshop-3.jpg',
    alt: 'Creatieve sfeer tijdens Sip & Paint',
  },
  {
    src: '/images/sip-and-paint/resultaat-3.jpg',
    alt: 'Kunstwerk uit een eerdere Sip & Paint-workshop',
  },
  {
    src: '/images/sip-and-paint/resultaat-4.jpg',
    alt: 'Voorbeeld van een werk uit Sip & Paint',
  },
];
---

<Layout
  title="Sip & Paint | Kunst On(t)leed"
  description="Ontdek de workshop Sip & Paint tijdens Kunst On(t)leed in Gits. Een gezellige en laagdrempelige workshop met kunstenaar Steven Selschotter."
>
  <section class="sip-page">
    <div class="sip-intro">
      <p class="kicker">Workshop</p>
      <h1>Sip & Paint</h1>
      <p class="lead">
        Op zondag 31 mei 2026 kan je deelnemen aan de workshop Sip & Paint. Samen met
        kunstenaar Steven Selschotter dompel je je voor 2 uur onder in een spetterende
        wereld vol verf en Kunst. Ervaring is niet nodig.
      </p>
    </div>

    <section class="sip-slider-section">
      <div class="sip-slider" data-sip-slider>
        <button class="slider-arrow slider-arrow-left" type="button" aria-label="Vorige foto" data-prev>
          ‹
        </button>

        <div class="slider-viewport">
          {sfeerbeelden.map((beeld, index) => (
            <figure class={`slide ${index === 0 ? 'is-active' : ''}`}>
              <img src={beeld.src} alt={beeld.alt} loading={index === 0 ? 'eager' : 'lazy'} />
            </figure>
          ))}
        </div>

        <button class="slider-arrow slider-arrow-right" type="button" aria-label="Volgende foto" data-next>
          ›
        </button>
      </div>
    </section>

    <section class="sip-text-card">
      <p>
        Wil je jouw creatieve duivels ontbinden? Heb je noch het talent, noch de skills,
        maar wil je je graag uitleven met kleur, compositie en techniek? Én wil je
        ondertussen genieten van een goed glas op een gezellig terras? Dat kan! Schrijf je
        in voor de workshop Sip & Paint en dompel je voor 2 uur onder in een spetterende
        wereld vol verf en Kunst. Samen met kunstenaar Steven Selschotter speelt elke
        artistieke avonturier het klaar om na twee uur te pronken met een fris en
        eigentijds kunstwerk.
      </p>
    </section>

    <section class="sip-praktisch">
      <div class="info-card">
        <h2>Wanneer</h2>
        <p>Zondag 31 mei 2026</p>
      </div>

      <div class="info-card">
        <h2>Sessies</h2>
        <p>Start om 13.30u of 16u</p>
      </div>

      <div class="info-card">
        <h2>Duur</h2>
        <p>2 uur</p>
      </div>

      <div class="info-card">
        <h2>Begeleiding</h2>
        <p>Steven Selschotter</p>
      </div>

      <div class="info-card">
        <h2>Prijs</h2>
        <p>Kostprijs alles in is 40€</p>
      </div>

      <div class="info-card">
        <h2>Aantal deelnemers</h2>
        <p>Maximum 15 personen per sessie</p>
      </div>

      <div class="info-card info-card-wide">
        <h2>Inschrijven</h2>
        <p>
        Inschrijven kan via onderstaande link. <br>
        https://eventalix.org/events/70f336f9-51a4-4908-b1ce-d19a78354108/orders
        </p>
      </div>
    </section>
  </section>
</Layout>

<style>
  .sip-page {
    width: min(1120px, calc(100% - 2.5rem));
    margin: 0 auto;
    padding: 3.5rem 0 5.5rem;
  }

  .sip-intro {
    max-width: 860px;
    margin-bottom: 1.6rem;
  }

  .kicker {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9d0f2f;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 5.2rem);
    line-height: 0.95;
    color: #9d0f2f;
  }

  .lead {
    max-width: 780px;
    margin: 1.5rem 0 0;
    font-size: 1.08rem;
    line-height: 1.8;
    color: #3f302c;
  }

  .sip-slider-section {
    margin-bottom: 1.8rem;
  }

  .sip-slider {
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid rgba(157, 15, 47, 0.12);
    background: rgba(255, 255, 255, 0.22);
    box-shadow: 0 12px 30px rgba(96, 47, 34, 0.05);
  }

  .slider-viewport {
    position: relative;
    aspect-ratio: 16 / 9;
    min-height: 320px;
  }

  .slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease;
  }

  .slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
    border: none;
    border-radius: 999px;
    background: rgba(251, 243, 230, 0.92);
    color: #9d0f2f;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.12);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .slider-arrow:hover {
    opacity: 0.85;
  }

  .slider-arrow-left {
    left: 1rem;
  }

  .slider-arrow-right {
    right: 1rem;
  }

  .sip-text-card,
  .info-card,
  .sip-extra-text {
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(157, 15, 47, 0.12);
    border-radius: 2rem;
    box-shadow: 0 12px 30px rgba(96, 47, 34, 0.05);
  }

  .sip-text-card {
    padding: 2rem 2rem 1.9rem;
    margin-bottom: 1.75rem;
  }

  .sip-text-card p {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.85;
    color: #3f302c;
  }

  .sip-praktisch {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .info-card {
    padding: 1.4rem 1.4rem 1.25rem;
  }

  .info-card h2 {
    margin: 0 0 0.55rem;
    font-size: 1.15rem;
    color: #9d0f2f;
  }

  .info-card p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #3f302c;
  }

  .info-card-wide {
    grid-column: 1 / -1;
  }

  .sip-extra-text {
    padding: 1.4rem 1.6rem;
  }

  .sip-extra-text p {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #3f302c;
  }

  @media (max-width: 900px) {
    .sip-praktisch {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .slider-viewport {
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 640px) {
    .sip-page {
      width: min(100%, calc(100% - 1.5rem));
      padding: 2.4rem 0 4.5rem;
    }

    .lead {
      font-size: 1rem;
      line-height: 1.75;
    }

    .slider-viewport {
      min-height: 240px;
    }

    .slider-arrow {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 1.7rem;
    }

    .slider-arrow-left {
      left: 0.7rem;
    }

    .slider-arrow-right {
      right: 0.7rem;
    }

    .sip-text-card {
      padding: 1.45rem 1.2rem 1.35rem;
      border-radius: 1.5rem;
    }

    .sip-text-card p {
      font-size: 0.98rem;
      line-height: 1.75;
    }

    .sip-praktisch {
      grid-template-columns: 1fr;
    }

    .info-card {
      padding: 1.2rem 1.15rem 1.1rem;
      border-radius: 1.4rem;
    }

    .sip-extra-text {
      padding: 1.2rem 1.15rem;
      border-radius: 1.4rem;
    }
  }
</style>

<script>
  const slider = document.querySelector('[data-sip-slider]');

  if (slider) {
    const slides = Array.from(slider.querySelectorAll('.slide'));
    const prevButton = slider.querySelector('[data-prev]');
    const nextButton = slider.querySelector('[data-next]');
    let activeIndex = 0;
    let intervalId;

    const showSlide = (index) => {
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === index);
      });
      activeIndex = index;
    };

    const nextSlide = () => {
      const newIndex = (activeIndex + 1) % slides.length;
      showSlide(newIndex);
    };

    const prevSlide = () => {
      const newIndex = (activeIndex - 1 + slides.length) % slides.length;
      showSlide(newIndex);
    };

    const restartInterval = () => {
      clearInterval(intervalId);
      intervalId = setInterval(nextSlide, 10000);
    };

    nextButton?.addEventListener('click', () => {
      nextSlide();
      restartInterval();
    });

    prevButton?.addEventListener('click', () => {
      prevSlide();
      restartInterval();
    });

    restartInterval();
  }
</script>