---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="route-hero">
    <p class="route-kicker">Verken het traject</p>
    <h1>Parcours</h1>
    <p class="route-intro">
      Ontdek hier het parcours van Kunst on(t)leed. Op deze kaart zie je hoe het
      traject doorheen de locatie loopt en waar bezoekers de verschillende
      kunstpunten kunnen terugvinden.
    </p>
  </section>

  <section class="route-map-section">
    <figure class="route-map-card">
      <img
        src="/images/parcours.png"
        alt="Overzichtskaart van het parcours van Kunst on(t)leed"
        class="route-map"
      />
      <figcaption>
        Overzicht van het parcours van Kunst on(t)leed.
      </figcaption>
    </figure>
  </section>

  <section class="route-info-grid">
    <article class="route-info-card">
      <h2>Startpunt</h2>
      <p>
        Hier kun je later vermelden waar bezoekers best starten aan het parcours.
      </p>
    </article>

    <article class="route-info-card">
      <h2>Wandelrichting</h2>
      <p>
        Voeg hier later extra uitleg toe over hoe bezoekers het parcours het best
        volgen.
      </p>
    </article>

    <article class="route-info-card">
      <h2>Duur</h2>
      <p>
        Hier kun je later een schatting geven van hoe lang het parcours ongeveer
        duurt.
      </p>
    </article>

    <article class="route-info-card">
      <h2>Extra info</h2>
      <p>
        Voeg hier later bijvoorbeeld info toe over rustpunten, toegankelijkheid
        of praktische aandachtspunten onderweg.
      </p>
    </article>
  </section>
</Layout>

<style>
  .route-hero {
    padding: 2rem 0 1rem;
    max-width: 760px;
  }

  .route-kicker {
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .route-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.95;
  }

  .route-intro {
    margin-top: 1.25rem;
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 700px;
  }

  .route-map-section {
    margin-top: 2.5rem;
  }

  .route-map-card {
    margin: 0;
    background-color: rgba(251, 243, 230, 0.8);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
  }

  .route-map {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.9rem;
  }

  .route-map-card figcaption {
    margin-top: 0.9rem;
    font-size: 0.95rem;
    color: var(--text);
  }

  .route-info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .route-info-card {
    background-color: rgba(251, 243, 230, 0.8);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
  }

  .route-info-card h2 {
    margin: 0 0 0.9rem 0;
    font-size: 2rem;
    line-height: 1;
  }

  .route-info-card p {
    margin: 0;
    line-height: 1.75;
  }

  @media (max-width: 700px) {
    .route-info-grid {
      grid-template-columns: 1fr;
    }

    .route-info-card h2 {
      font-size: 1.7rem;
    }
  }
</style>