---
import Layout from '../../layouts/Layout.astro';
import { kunstenaars } from '../../data/kunstenaars.js';

export function getStaticPaths() {
  return kunstenaars.map((kunstenaar) => ({
    params: { slug: kunstenaar.slug },
    props: { kunstenaar }
  }));
}

const { kunstenaar } = Astro.props;
const afbeeldingen = kunstenaar.afbeeldingen ?? [];
---

<Layout
  title={`${kunstenaar.naam} | Kunstenaars | Kunst On(t)leed`}
  description={`Ontdek meer over ${kunstenaar.naam} tijdens Kunst On(t)leed.`}
>
  <section class="artist-detail-hero">
    <a href="/kunstenaars" class="artist-back-link">← Terug naar kunstenaars</a>

    <p class="artist-detail-kicker">Kunstenaars</p>
    <h1>{kunstenaar.naam}</h1>
    {kunstenaar.info && <p class="artist-detail-info">{kunstenaar.info}</p>}
  </section>

  <section class="artist-detail-layout">
    <div class="artist-detail-text">
      <details class="artist-dropdown">
        <summary>Wie is ?</summary>
        <div class="artist-dropdown-content">
          <p>{kunstenaar.wieIs}</p>
        </div>
      </details>

      <details class="artist-dropdown">
        <summary>Kunstwerk ?</summary>
        <div class="artist-dropdown-content">
          <p>{kunstenaar.kunstwerk}</p>
        </div>
      </details>

      <details class="artist-dropdown">
        <summary>Contactgegevens ?</summary>
        <div class="artist-dropdown-content">
          <p>{kunstenaar.contactgegevens}</p>
        </div>
      </details>
    </div>

    <div class="artist-detail-image-card">
      {afbeeldingen.length > 0 ? (
        <div class="artist-carousel" data-carousel>
          <div class="artist-carousel-slides" data-carousel-slides>
            {afbeeldingen.map((afbeelding, index) => (
              <img
                src={afbeelding}
                alt={`Kunstwerk van ${kunstenaar.naam} - foto ${index + 1}`}
                class:list={[
                  'artist-detail-image',
                  'artist-carousel-image',
                  index === 0 && 'is-active'
                ]}
                data-carousel-image
                data-index={index}
                tabindex="0"
                role="button"
                aria-label={`Open foto ${index + 1} groter`}
              />
            ))}
          </div>

          {afbeeldingen.length > 1 && (
            <>
              <button class="artist-carousel-button prev" type="button" aria-label="Vorige foto">
                ‹
              </button>
              <button class="artist-carousel-button next" type="button" aria-label="Volgende foto">
                ›
              </button>
            </>
          )}
        </div>
      ) : (
        <div class="artist-image-placeholder">
          <span>Foto volgt later</span>
        </div>
      )}
    </div>
  </section>

  {afbeeldingen.length > 0 && (
    <div class="artist-lightbox" data-lightbox aria-hidden="true">
      <button class="artist-lightbox-close" type="button" aria-label="Sluiten">
        ×
      </button>

      {afbeeldingen.length > 1 && (
        <button class="artist-lightbox-button prev" type="button" aria-label="Vorige foto">
          ‹
        </button>
      )}

      <div class="artist-lightbox-content" data-lightbox-content>
        <img
          src={afbeeldingen[0]}
          alt={`Kunstwerk van ${kunstenaar.naam} groot weergegeven`}
          class="artist-lightbox-image"
          data-lightbox-image
        />
      </div>

      {afbeeldingen.length > 1 && (
        <button class="artist-lightbox-button next" type="button" aria-label="Volgende foto">
          ›
        </button>
      )}
    </div>
  )}

  <script is:inline>
    function initArtistCarousels() {
      document.querySelectorAll('[data-carousel]').forEach((carousel) => {
        if (carousel.dataset.initialized === 'true') return;
        carousel.dataset.initialized = 'true';

        const images = carousel.querySelectorAll('[data-carousel-image]');
        const slides = carousel.querySelector('[data-carousel-slides]');
        const prevButton = carousel.querySelector('.artist-carousel-button.prev');
        const nextButton = carousel.querySelector('.artist-carousel-button.next');

        const lightbox = document.querySelector('[data-lightbox]');
        const lightboxImage = lightbox?.querySelector('[data-lightbox-image]');
        const lightboxContent = lightbox?.querySelector('[data-lightbox-content]');
        const lightboxClose = lightbox?.querySelector('.artist-lightbox-close');
        const lightboxPrev = lightbox?.querySelector('.artist-lightbox-button.prev');
        const lightboxNext = lightbox?.querySelector('.artist-lightbox-button.next');

        if (!images.length) return;

        let currentIndex = 0;
        let autoplayId;
        let touchStartX = 0;
        let touchEndX = 0;
        let lightboxTouchStartX = 0;
        let lightboxTouchEndX = 0;

        const showSlide = (index) => {
          images[currentIndex]?.classList.remove('is-active');
          currentIndex = index;
          images[currentIndex]?.classList.add('is-active');

          if (lightboxImage && lightbox.classList.contains('is-open')) {
            lightboxImage.src = images[currentIndex].getAttribute('src');
            lightboxImage.alt = images[currentIndex].getAttribute('alt') ?? '';
          }
        };

        const nextSlide = () => {
          const nextIndex = (currentIndex + 1) % images.length;
          showSlide(nextIndex);
        };

        const prevSlide = () => {
          const prevIndex = (currentIndex - 1 + images.length) % images.length;
          showSlide(prevIndex);
        };

        const startAutoplay = () => {
          if (images.length <= 1) return;
          stopAutoplay();
          autoplayId = window.setInterval(nextSlide, 6000);
        };

        const stopAutoplay = () => {
          if (autoplayId) {
            window.clearInterval(autoplayId);
          }
        };

        const openLightbox = (index) => {
          if (!lightbox || !lightboxImage) return;

          showSlide(index);
          lightboxImage.src = images[currentIndex].getAttribute('src');
          lightboxImage.alt = images[currentIndex].getAttribute('alt') ?? '';
          lightbox.classList.add('is-open');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.classList.add('lightbox-open');
          stopAutoplay();
        };

        const closeLightbox = () => {
          if (!lightbox) return;

          lightbox.classList.remove('is-open');
          lightbox.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('lightbox-open');
          startAutoplay();
        };

        prevButton?.addEventListener('click', () => {
          prevSlide();
          startAutoplay();
        });

        nextButton?.addEventListener('click', () => {
          nextSlide();
          startAutoplay();
        });

        images.forEach((image, index) => {
          image.addEventListener('click', () => openLightbox(index));

          image.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              openLightbox(index);
            }
          });
        });

        carousel.addEventListener('mouseenter', stopAutoplay);
        carousel.addEventListener('mouseleave', startAutoplay);

        slides?.addEventListener('touchstart', (event) => {
          touchStartX = event.changedTouches[0].clientX;
        });

        slides?.addEventListener('touchend', (event) => {
          touchEndX = event.changedTouches[0].clientX;
          const diff = touchEndX - touchStartX;

          if (Math.abs(diff) < 50) return;

          if (diff < 0) {
            nextSlide();
          } else {
            prevSlide();
          }

          startAutoplay();
        });

        lightboxClose?.addEventListener('click', closeLightbox);

        lightbox?.addEventListener('click', (event) => {
          if (event.target === lightbox) {
            closeLightbox();
          }
        });

        lightboxPrev?.addEventListener('click', () => {
          prevSlide();
        });

        lightboxNext?.addEventListener('click', () => {
          nextSlide();
        });

        lightboxContent?.addEventListener('touchstart', (event) => {
          lightboxTouchStartX = event.changedTouches[0].clientX;
        });

        lightboxContent?.addEventListener('touchend', (event) => {
          lightboxTouchEndX = event.changedTouches[0].clientX;
          const diff = lightboxTouchEndX - lightboxTouchStartX;

          if (Math.abs(diff) < 50) return;

          if (diff < 0) {
            nextSlide();
          } else {
            prevSlide();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (!lightbox || !lightbox.classList.contains('is-open')) return;

          if (event.key === 'Escape') {
            closeLightbox();
          }

          if (event.key === 'ArrowRight' && images.length > 1) {
            nextSlide();
          }

          if (event.key === 'ArrowLeft' && images.length > 1) {
            prevSlide();
          }
        });

        startAutoplay();
      });
    }

    initArtistCarousels();
    document.addEventListener('astro:page-load', initArtistCarousels);
  </script>
</Layout>

<style>
  .artist-detail-hero {
    padding: 2rem 0 1rem;
    max-width: 760px;
  }

  .artist-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1rem;
    color: var(--title);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .artist-back-link:hover {
    text-decoration: underline;
  }

  .artist-detail-kicker {
    margin: 0 0 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .artist-detail-hero h1 {
    margin: 0;
    font-size: clamp(2.8rem, 6vw, 4.4rem);
    line-height: 0.95;
  }

  .artist-detail-info {
    margin: 1rem 0 0;
    display: inline-block;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background-color: rgba(236, 163, 10, 0.12);
    border: 1px solid rgba(236, 163, 10, 0.22);
    font-size: 1rem;
    line-height: 1.25;
    font-weight: 600;
    color: var(--text);
  }

  .artist-detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 420px);
    gap: 2rem;
    align-items: start;
    margin-top: 1.8rem;
    padding-bottom: 2.75rem;
  }

  .artist-detail-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .artist-dropdown {
    background: linear-gradient(180deg, rgba(251, 243, 230, 0.96), rgba(245, 234, 215, 0.92));
    border: 1px solid var(--border);
    border-radius: 1.15rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
    overflow: hidden;
  }

  .artist-dropdown summary {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1.2rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .artist-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .artist-dropdown summary::before {
    content: '⌄';
    font-size: 1.1rem;
    line-height: 1;
    color: var(--title);
    transition: transform 0.2s ease;
  }

  .artist-dropdown[open] summary::before {
    transform: rotate(180deg);
  }

  .artist-dropdown-content {
    padding: 0 1.2rem 1.2rem;
  }

  .artist-dropdown-content p {
    margin: 0;
    line-height: 1.75;
    font-size: 1rem;
    white-space: pre-line;
  }

  .artist-detail-image-card {
    background: linear-gradient(180deg, rgba(251, 243, 230, 0.96), rgba(245, 234, 215, 0.92));
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 24px rgba(58, 36, 31, 0.05);
  }

  .artist-detail-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.9rem;
  }

  .artist-carousel {
    position: relative;
  }

  .artist-carousel-slides {
    position: relative;
  }

  .artist-carousel-image {
    display: none;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: contain;
    object-position: center;
    border-radius: 0.9rem;
    background: rgba(251, 243, 230, 0.8);
    cursor: zoom-in;
  }

  .artist-carousel-image.is-active {
    display: block;
  }

  .artist-carousel-button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid rgba(58, 36, 31, 0.12);
    border-radius: 999px;
    background: rgba(251, 243, 230, 0.86);
    color: var(--title);
    font-size: 1.55rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    box-shadow: 0 6px 18px rgba(58, 36, 31, 0.08);
    transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .artist-carousel-button:hover {
    background: rgba(251, 243, 230, 0.98);
    box-shadow: 0 8px 22px rgba(58, 36, 31, 0.12);
  }

  .artist-carousel-button.prev {
    left: 0.75rem;
  }

  .artist-carousel-button.next {
    right: 0.75rem;
  }

  .artist-image-placeholder {
    min-height: 420px;
    border-radius: 0.9rem;
    background:
      linear-gradient(180deg, rgba(236, 163, 10, 0.08), rgba(191, 101, 22, 0.08)),
      rgba(251, 243, 230, 0.7);
    border: 1px dashed rgba(143, 16, 39, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
  }

  .artist-image-placeholder span {
    color: var(--title);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .artist-lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(30, 20, 17, 0.78);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .artist-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .artist-lightbox-content {
    max-width: min(90vw, 980px);
    max-height: 82vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .artist-lightbox-image {
    max-width: 100%;
    max-height: 82vh;
    display: block;
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  }

  .artist-lightbox-close,
  .artist-lightbox-button {
    position: absolute;
    border: none;
    border-radius: 999px;
    background: rgba(251, 243, 230, 0.92);
    color: var(--title);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.18);
  }

  .artist-lightbox-close {
    top: 1.25rem;
    right: 1.25rem;
    width: 2.7rem;
    height: 2.7rem;
    font-size: 2rem;
    line-height: 1;
  }

  .artist-lightbox-button {
    top: 50%;
    transform: translateY(-50%);
    width: 2.9rem;
    height: 2.9rem;
    font-size: 1.9rem;
    line-height: 1;
  }

  .artist-lightbox-button.prev {
    left: 1.25rem;
  }

  .artist-lightbox-button.next {
    right: 1.25rem;
  }

  :global(body.lightbox-open) {
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .artist-detail-layout {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }

    .artist-detail-image-card {
      order: -1;
    }

    .artist-image-placeholder {
      min-height: 300px;
    }
  }

  @media (max-width: 600px) {
    .artist-detail-hero {
      padding: 1rem 0 0.5rem;
    }

    .artist-back-link {
      margin-bottom: 0.8rem;
      font-size: 0.92rem;
    }

    .artist-detail-kicker {
      margin-bottom: 0.55rem;
      font-size: 0.8rem;
    }

    .artist-detail-hero h1 {
      font-size: clamp(2.3rem, 11vw, 3.4rem);
    }

    .artist-detail-layout {
      margin-top: 1.2rem;
      padding-bottom: 2.2rem;
    }

    .artist-dropdown summary {
      padding: 1rem 1rem;
      font-size: 1rem;
    }

    .artist-dropdown-content {
      padding: 0 1rem 1rem;
    }

    .artist-carousel-button {
      width: 2.15rem;
      height: 2.15rem;
      font-size: 1.35rem;
    }

    .artist-lightbox {
      padding: 1rem;
    }

    .artist-lightbox-close {
      top: 0.85rem;
      right: 0.85rem;
      width: 2.45rem;
      height: 2.45rem;
      font-size: 1.8rem;
    }

    .artist-lightbox-button {
      width: 2.45rem;
      height: 2.45rem;
      font-size: 1.55rem;
    }

    .artist-lightbox-button.prev {
      left: 0.6rem;
    }

    .artist-lightbox-button.next {
      right: 0.6rem;
    }

    .artist-image-placeholder {
      min-height: 240px;
    }
  }
</style>